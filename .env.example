# Langfuse API Keys (用于日志和监控)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=http://localhost:3000

# Tavily API Key (用于网络搜索)
TAVILY_API_KEY=your_tavily_api_key_here

# Embedding API Configuration (用于文本嵌入)
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://api.example.com/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3

# 数据存储配置（纯本地 SQLite/libSQL，无需任何独立 server）
# 向量库（libSQL）存储目录；每个逻辑库对应一个 .db 文件
VECTOR_DB_PATH=data/vector_store
VECTOR_DB_DATABASE=examples
VECTOR_DB_DATABASE_RESUME=resume
# 简历结构化数据（SQLite 单文件）
RESUME_DB_PATH=data/app.db
# 简历原始文件本地存储目录
RESUME_STORAGE_PATH=data/resumes
# SQL 助手目标业务库（SQLite 单文件；需自行灌入业务样例数据）
SQLBOT_DB_PATH=data/sqlbot.db

# OpenAI API Configuration (DeepSeek)
OPENAI_API_KEY_DEEPSEEK=your_deepseek_api_key_here
OPENAI_API_BASE_DEEPSEEK=https://api.deepseek.com/v1

# OpenAI API Configuration (SiliconCloud)
OPENAI_API_KEY_SILICONCLOUD=your_siliconcloud_api_key_here
OPENAI_API_BASE_SILICONCLOUD=https://api.siliconflow.cn/v1

# LLM Configuration
LLM_PROVIDER=SILICONCLOUD
LLM_MODEL=Qwen/Qwen2-72B-Instruct

# Uncomment and set the following if needed:
# LLM_MODEL=Qwen/Qwen1.5-32B-Chat